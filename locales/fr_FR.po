msgstr "Chargement..."

msgid "Cancel"
msgstr "Annuler"

msgid "Clone"
msgstr "Cloner"

msgid "Unable to open the cloning dialog. Check browser console."
msgstr "Impossible d'ouvrir la fenêtre de clonage. Vérifiez la console du navigateur."

